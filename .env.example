# Opcionales: si se definen, sobreescriben las credenciales por defecto del código.
# Si se dejan vacías, la app usa el proyecto Supabase por defecto (como antes).
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Desarrollo del front SIN Supabase (datos mock).
# Solo para dev local: ponlo en 'true' en tu .env.local.
# NUNCA lo actives en producción (Vercel / GitHub Pages) — quedaría OFF por defecto.
# Con VITE_USE_MOCKS=true no se necesitan las credenciales de Supabase de arriba.
VITE_USE_MOCKS=false
